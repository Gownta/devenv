# ~/.zlogin — sourced for login shells, after .zshrc.
#
# One-time login actions (not environment setup — that goes in .zprofile).

# OnDemand: repos may not be mounted yet at login, so patch their hgrc files in
# a detached background process that retries until the repos appear.
if grep -q '^DEVICE_HOSTNAME_SCHEME=od$' /etc/fbwhoami 2>/dev/null; then
  ( "$NJORMROD_DEVENV/bin/hgrc_monkeypatch.py" & ) >/dev/null 2>&1
fi


# Per-host overrides, last word.
[ -v ENVRCDIR ] && maybe_source "$ENVRCDIR/zlogin"
