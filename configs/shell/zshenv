export NJORMROD_DEVENV="$HOME/dev/devenv"

# Keep path entries unique.
# (N) prunes directories that do not exist.
# Do not prune edenfs dirs, since they might mount slowly.
typeset -U path PATH
path=(
  .
  $HOME/bin(N)
  $HOME/fbsource/users/nj/njormrod/bin
  $HOME/dev/devenv/bin(N)

  /var/www/scripts/bin(N)

  $HOME/dev/libai/bin(N)
  $HOME/dev/homebrew/bin(N)
  $HOME/dev/homebrew/sbin(N)
  $HOME/dev/bazel/bin(N)
  $HOME/.local/bin(N)
  $HOME/repos/dotfbsource/xplat/third-party/node/bin
  $HOME/repos/dotfbsource/xplat/third-party/yarn
  $HOME/dev/rust/cargo/bin(N)

  $path
)
export PATH

# Prompt
export PROMPT_VAR_ART="%F{red}❱%F{208}❱%F{green}❱%f"

# Rust
# Instructions from https://www.rust-lang.org/tools/install are to run
# curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh
export RUSTUP_HOME=$HOME/dev/rust/rustup
export CARGO_HOME=$HOME/dev/rust/cargo

# General
export EDITOR=/usr/bin/vim

# Common command controls
# man ls to see color options
export COLORTERM=truecolor
export CLICOLOR=1
export LSCOLORS=cxgxcxdxfxegedabagacad

# Cosmos
export COSMOS_BIN=/Users/njormrod/dev/starlang/cosmos/bin

################################################################################
#### ENVRCDIR
################################################################################

# Per-host config dir (ENVRCDIR), selected from /etc/fbwhoami or AWS detection.
if [ "$(hostname)" = "elyra" ]; then
  export ENVRCDIR="$NJORMROD_DEVENV/envs/personal_mbp"
elif [ -f /etc/fbwhoami ]; then
  # Meta-managed host (devserver).
  envs_dir="$HOME/fbsource/users/nj/njormrod/envs"
  if grep -q '^DEVICE_HOSTNAME_SCHEME=od$' /etc/fbwhoami; then
    candidates=(od default)
  else
    device="$(sed -n 's/^DEVICE_NAME=//p' /etc/fbwhoami)"
    candidates=("${device%.facebook.com}" default)
  fi
  for candidate in $candidates; do
    if [ -n "$candidate" ] && [ -d "$envs_dir/$candidate" ]; then
      export ENVRCDIR="$envs_dir/$candidate"
      break
    fi
  done
  unset envs_dir device candidates candidate
elif [ "$(head -n1 /sys/devices/virtual/dmi/id/sys_vendor 2>/dev/null)" = "Amazon EC2" ]; then
  # AWS EC2 instance.
  export ENVRCDIR="$NJORMROD_DEVENV/envs/cloud_linux"
else
  # Other host (e.g. laptop).
  export ENVRCDIR="$NJORMROD_DEVENV/envs/mbp"
fi

# Source the per-host equivalent in $ENVRCDIR, if present.
# (maybe_source isn't defined yet — it lives in functions, sourced by .zshrc.)
[ -f "$ENVRCDIR/zshenv" ] && source "$ENVRCDIR/zshenv"
